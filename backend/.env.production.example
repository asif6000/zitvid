# Production Environment Variables
# Copy to backend/.env on server (public_html/api/.env)

NODE_ENV=production
PORT=3000

# Database - Use external PostgreSQL (Supabase, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# JWT Secret - Generate: openssl rand -base64 32
JWT_SECRET="your-32-char-random-secret-here"

# Frontend URL - Exact match, no trailing slash
FRONTEND_URL="https://zinvid.com"

# Optional: Payment Gateways
NAGAD_MERCHANT_ID=""
NAGAD_API_KEY=""
NAGAD_CALLBACK_URL="https://zinvid.com/api/payment/nagad/callback"

RUPANTORPAY_MERCHANT_ID=""
RUPANTORPAY_API_KEY=""
RUPANTORPAY_CALLBACK_URL="https://zinvid.com/api/payment/rupantorpay/callback"

UDDOKTA_API_KEY=""
UDDOKTA_CALLBACK_URL="https://zinvid.com/api/payment/uddokta/callback"

# Optional: Email (if using)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@zinvid.com"